# Development defaults
PORT=3050
# SQLite database location
WHATSAPP_DATABASE_PATH=data/whatsapp-monitor.sqlite
# Legacy seed for the employees table on first startup
WHATSAPP_EMPLOYEE_IDS=anna
# Shared password for the MVP auth flow
AUTH_PASSWORD=0000
# You can use either an absolute path or a path relative to the project root.
WHATSAPP_SESSION_DIR=sessions
