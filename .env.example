# Development defaults
PORT=3050
# SQLite database location
WHATSAPP_DATABASE_PATH=data/whatsapp-monitor.sqlite
# Shared password for the MVP auth flow
AUTH_PASSWORD=0000
# You can use either an absolute path or a path relative to the project root.
WHATSAPP_SESSION_DIR=sessions
# Local report export directory. Relative paths are resolved from the project root.
REPORTS_DIR=reports

WHATSAPP_CHAT_SYNC_INTERVAL_MS=60000
WHATSAPP_CHAT_SYNC_INITIAL_DELAY_MS=15000
WHATSAPP_CHAT_SYNC_EMPLOYEE_CONCURRENCY=1
WHATSAPP_SESSION_ACTIVITY_SYNC_INTERVAL_MS=10000