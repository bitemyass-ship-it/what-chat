{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "next": [
        "frontend/node_modules/next"
      ],
      "next/*": [
        "frontend/node_modules/next/*"
      ],
      "react": [
        "frontend/node_modules/react"
      ],
      "react/*": [
        "frontend/node_modules/react/*"
      ],
      "react-dom": [
        "frontend/node_modules/react-dom"
      ],
      "react-dom/*": [
        "frontend/node_modules/react-dom/*"
      ],
      "@/*": [
        "frontend/src/*"
      ]
    },
    "typeRoots": [
      "./node_modules/@types",
      "./frontend/node_modules/@types"
    ],
    "types": [
      "node",
      "jest"
    ]
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}
